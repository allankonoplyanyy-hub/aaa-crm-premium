# AAA CRM Premium — environment variables

# --- Database (Neon PostgreSQL) ---
# When set, the app uses PostgreSQL (schema in db/migrations/, applied via
# `node scripts/migrate.mjs`). When empty, it falls back to the in-memory
# demo store — no external services required.
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# --- Demo mode ---
# "true" (default) shows quick-login buttons, demo password hints and
# "Демо" banners. Set to "false" for customer-facing deployments.
NEXT_PUBLIC_DEMO_MODE=true

# --- Integration API v1 (/api/v1/leads, /api/v1/voice-events) ---
# Shared HMAC secret for service-to-service webhooks. Required only if you
# use the integration API. Generate with: openssl rand -hex 32
# INTEGRATION_WEBHOOK_SECRET=

# --- Seed users' demo password (defaults to demo1234) ---
# Self-registered users always get scrypt-hashed individual passwords.
# DEMO_PASSWORD=demo1234
