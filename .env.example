# AAA CRM Premium — environment variables
#
# The demo build runs entirely on an in-memory store and needs NO secrets.
# All variables below are optional toggles or placeholders for the future
# production setup (see CODEX_HANDOFF.md, section "Production blockers").

# Demo mode. "true" (default) shows quick-login buttons, demo password hints
# and "Демо" banners. Set to "false" to hide all demo affordances.
NEXT_PUBLIC_DEMO_MODE=true

# --- Placeholders for production (NOT used by the current code) ---
# PostgreSQL connection string (e.g. Neon). Required before real deployment.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Secret for signed session cookies once real auth replaces the demo cookie.
# AUTH_SECRET=generate-with: openssl rand -base64 32
